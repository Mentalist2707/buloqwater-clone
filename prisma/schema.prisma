// ============================================================
// BULOQWATER - Multi-Tenant SaaS Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  DIRECTOR
  OPERATOR
  DRIVER
  CUSTOMER
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

enum OrderStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentType {
  CASH
  CLICK
  CREDIT
}

enum ProductUnit {
  PIECE
  LITER
}

enum ProductCategory {
  WATER        // 💧 Suvlar
  PROMO        // 🔥 Aksiyalar
  ACCESSORIES  // 🔧 Aksessuarlar
}

// ============================================================
// COMPANY (Kompaniya) - Multi-tenant asosi
// ============================================================

model Company {
  id          String        @id @default(uuid())
  name        String
  subdomain   String        @unique
  status      CompanyStatus @default(ACTIVE)
  phone       String?
  address     String?
  logoUrl     String?
  maxCustomers Int          @default(500)   // Limit: maksimal mijozlar
  maxUsers     Int          @default(20)    // Limit: maksimal xodimlar
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  users         User[]
  customers     Customer[]
  products      Product[]
  orders        Order[]
  subscription  Subscription?
  activityLogs  ActivityLog[]

  @@index([subdomain])
  @@map("companies")
}

// ============================================================
// SUBSCRIPTION (Obuna) - Kompaniya to'lov muddati
// ============================================================

model Subscription {
  id          String    @id @default(uuid())
  startDate   DateTime  @default(now())
  endDate     DateTime                    // Obuna tugash sanasi
  amount      Float     @default(0)       // To'langan summa
  isPaid      Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId   String    @unique
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  payments    Payment[]

  @@map("subscriptions")
}

// ============================================================
// PAYMENT (To'lovlar tarixi)
// ============================================================

model Payment {
  id          String    @id @default(uuid())
  amount      Float
  description String?
  paidAt      DateTime  @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("payments")
}

// ============================================================
// ACTIVITY LOG (Faoliyat jurnali)
// ============================================================

model ActivityLog {
  id          String    @id @default(uuid())
  action      String    // "company_created", "user_login", "order_delivered"
  description String    // "Shifo kompaniyasi yaratildi"
  metadata    String?   // JSON qo'shimcha ma'lumot
  createdAt   DateTime  @default(now())

  userId      String?
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([companyId])
  @@index([action])
  @@map("activity_logs")
}

// ============================================================
// USER (Foydalanuvchi)
// ============================================================

model User {
  id          String    @id @default(uuid())
  name        String
  phone       String
  password    String
  role        Role      @default(OPERATOR)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  assignedOrders  Order[] @relation("DriverOrders")
  createdOrders   Order[] @relation("OperatorOrders")

  @@unique([phone, companyId])
  @@index([companyId])
  @@index([role])
  @@map("users")
}

// ============================================================
// CUSTOMER (Mijoz)
// ============================================================

model Customer {
  id            String    @id @default(uuid())
  name          String
  phone1        String
  phone2        String?
  address       String
  landmark      String?
  locationLink  String?
  notes         String?
  bottleBalance Int       @default(0)
  debtBalance   Float     @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  orders        Order[]

  @@unique([phone1, companyId])
  @@index([companyId])
  @@index([phone1])
  @@map("customers")
}

// ============================================================
// PRODUCT (Mahsulot)
// ============================================================

model Product {
  id          String          @id @default(uuid())
  name        String
  description String?
  price       Float
  category    ProductCategory @default(WATER)
  unit        ProductUnit     @default(PIECE)
  isBottle    Boolean         @default(true)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  companyId   String
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  orderItems  OrderItem[]

  @@index([companyId])
  @@index([category])
  @@map("products")
}

// ============================================================
// ORDER (Buyurtma)
// ============================================================

model Order {
  id              String      @id @default(uuid())
  orderNumber     Int
  status          OrderStatus @default(PENDING)
  paymentType     PaymentType?
  totalAmount     Float       @default(0)
  paidAmount      Float       @default(0)
  bottlesDelivered  Int       @default(0)
  bottlesReturned   Int       @default(0)
  notes           String?
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  companyId       String
  company         Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id])

  operatorId      String?
  operator        User?       @relation("OperatorOrders", fields: [operatorId], references: [id])

  driverId        String?
  driver          User?       @relation("DriverOrders", fields: [driverId], references: [id])

  items           OrderItem[]

  @@unique([orderNumber, companyId])
  @@index([companyId])
  @@index([status])
  @@index([driverId])
  @@index([customerId])
  @@index([createdAt])
  @@map("orders")
}

// ============================================================
// ORDER ITEM (Buyurtma tarkibi)
// ============================================================

model OrderItem {
  id          String    @id @default(uuid())
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  orderId     String
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId   String
  product     Product   @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}
